{
    "manifest_version": 3,
    "name": "YouTube Music Hotkeys Fork",
    "version" : "3.0.1",
    "description": "Use keyboard shortcuts to control YouTube Music",
    "homepage_url": "https://github.com/langgregor/youtube-music-hotkeys",
    "author": "langgregor (forked from lidel's google-music-hotkeys)",
    "icons": {
        "128": "Play_music_triangle.png"
    },

    "permissions": [
        "contextMenus",
        "tabs",
        "scripting"
    ],

    "host_permissions": [
        "https://music.youtube.com/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "options_ui": {
        "page": "options.html"
    },

    "action": {
        "default_icon": {
            "128": "Play_music_triangle.png"
        }
    },

	"commands": {
		"toggle-playback": {
			"description": "Toggle Playback"
		},
		"previous-song": {
			"description": "Previous Song"
		},
		"next-song": {
			"description": "Next Song"
		},
        "volume-up": {
            "description": "Volume Up"
        },
        "volume-down": {
            "description": "Volume Down"
        }
	},

    "content_scripts": [
        {
            "matches": [
              "https://music.youtube.com/*"
            ],
            "js": ["autoplay.js"],
            "all_frames" : false,
            "run_at": "document_idle"
        }
    ]

}
